upstream uwsgi_app{
    server unix:/code/winimarket_app/uwsgi_app.sock;
}

server {
    listen 80;
    server_name www.winimarketgh.com winimarketgh.com;

    client_max_body_size 50M;

    error_log stderr warn;
    access_log /dev/stdout main;

    location / {
        include /etc/nginx/uwsgi_params;
        uwsgi_pass uwsgi_app;
    }

    location /static/ {
        alias /code/winimarket_app/static/;
    }

    location /media/ {
        alias /code/winimarket_app/media/;
    }
}